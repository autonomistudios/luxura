# ─── LuxAura B2B Operating System — Environment Variables ────────────────────
# Copy this file to .env and fill in all values.
# NEVER commit .env to git — it contains secrets.
# All server-side vars (no VITE_ prefix) must also be set in Vercel dashboard.

# ─── Auth & Mode ──────────────────────────────────────────────────────────────
VITE_AUTH_REQUIRED=true          # Set false ONLY for local dev
VITE_SOVEREIGN_MODE=PROD

# ─── Google AI (Gemini) ───────────────────────────────────────────────────────
# Get from: aistudio.google.com → Get API Key → Create API Key
# Must start with AIza... (NOT AQ. which is an expired OAuth token)
GOOGLE_API_KEY=AIzaSy...
VITE_GOOGLE_API_KEY=AIzaSy...    # Same key, browser-safe copy

# ─── Firebase (client-side, safe to expose) ───────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Firebase Admin (server-side, Vercel only — NEVER in client .env) ─────────
# 1. Firebase Console → Project Settings → Service Accounts → Generate new private key
# 2. base64 encode: base64 -i serviceAccountKey.json (Mac/Linux) or PowerShell equivalent
# 3. Paste the single-line base64 string below
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_API_KEY=                # Same as VITE_FIREBASE_API_KEY (for server token verification)

# ─── Cron Security ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Must match CRON_SECRET set in Vercel. Protects /api/agents/* endpoints.
CRON_SECRET=

# ─── Webhook Security ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
# Used to sign webhook payloads sent to brand endpoints.
WEBHOOK_SECRET=

# ─── Stripe Billing (server-side, Vercel only) ────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_WEBHOOK_SECRET=whsec_...  # From Stripe → Webhooks → endpoint secret
STRIPE_PRICE_STUDIO=price_...    # Studio tier monthly price ID
STRIPE_PRICE_AGENCY=price_...    # Agency tier monthly price ID
STRIPE_PRICE_ENTERPRISE=price_...# Enterprise tier monthly price ID

# ─── VTO Services (server-side) ───────────────────────────────────────────────
FASHN_API_KEY=fa-...             # From fashn.ai dashboard (optional, VTO fallback)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ─── Vercel Cron Setup ────────────────────────────────────────────────────────
# vercel.json already configures the cron schedules.
# Add CRON_SECRET to Vercel env vars so agents reject unauthorized calls.
# Crons:
#   /api/agents/campaign-agent             → every 2 minutes
#   /api/agents/usage-reconciliation-agent → 1st of month
#   /api/agents/consistency-guardian       → Mondays 2am UTC
