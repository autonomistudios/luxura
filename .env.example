# ─── Google Gemini (existing) ─────────────────────────────────────────────────
VITE_GOOGLE_API_KEY=your_gemini_api_key_here

# ─── Firebase (create project at console.firebase.google.com) ────────────────
# 1. Create a new project
# 2. Enable Authentication → Google provider
# 3. Create Firestore database (start in production mode)
# 4. Project Settings → Your apps → Web app → copy config values below
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── PayPal (developer.paypal.com) ───────────────────────────────────────────
# 1. Create a REST API app in your PayPal developer dashboard
# 2. Copy Client ID + Secret below (use Sandbox for testing)
# 3. Create 3 subscription plans and paste their Plan IDs below
# 4. Register a webhook pointing to https://your-domain.vercel.app/api/paypal-webhook
#    Events to subscribe: BILLING.SUBSCRIPTION.ACTIVATED, .RENEWED, .CANCELLED, .SUSPENDED
VITE_PAYPAL_CLIENT_ID=sb
VITE_PAYPAL_PLAN_AURA=
VITE_PAYPAL_PLAN_SOVEREIGN=
VITE_PAYPAL_PLAN_LUMINARY=

# ─── PayPal (server-side — set in Vercel environment variables, NOT in .env) ─
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PLAN_AURA=
PAYPAL_PLAN_SOVEREIGN=
PAYPAL_PLAN_LUMINARY=
PAYPAL_SANDBOX=true

# ─── Firebase Admin (server-side — set in Vercel, NOT in .env) ───────────────
# 1. Firebase console → Project settings → Service accounts → Generate new private key
# 2. base64-encode the downloaded JSON:  base64 -i serviceAccountKey.json
# 3. Paste the result in Vercel's FIREBASE_SERVICE_ACCOUNT env var
FIREBASE_SERVICE_ACCOUNT=

