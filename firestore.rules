rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    // Caller is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Caller owns the user document
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Caller is the platform admin
    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.email == 'autonomistudiosllc@gmail.com' ||
         request.auth.token.email == 'louis@beapillar.org' ||
         request.auth.token.email.matches('(?i)^autonomistudiosllc@gmail\\.com$') ||
         request.auth.token.email.matches('(?i)^louis@beapillar\\.org$'));
    }

    // Write fields are only those whitelisted — prevents clients injecting arbitrary data
    function onlyFields(allowed) {
      return request.resource.data.keys().hasOnly(allowed);
    }

    // ── users/{uid} ───────────────────────────────────────────────────────────
    match /users/{uid} {

      // User reads their own doc; admin reads any
      allow read: if isOwner(uid) || isAdmin();

      // User creates their own doc on first login (free-tier provisioning only).
      // Sensitive fields are PINNED to free-tier defaults — real credits and paid tiers
      // are granted server-side via the Admin SDK (Stripe/PayPal webhooks), which bypasses
      // these rules. Prevents a client from self-granting credits or a paid tier at creation.
      // (.get(field, default) lets a legit create omit the field, but forbids any non-default value.)
      allow create: if isOwner(uid) && onlyFields([
        'uid', 'email', 'displayName', 'photoURL',
        'tier', 'imageCredits', 'videoCredits',
        'subscriptionId', 'subscriptionStatus', 'createdAt'
      ])
        && request.resource.data.get('tier', 'free') == 'free'
        && request.resource.data.get('imageCredits', 0) == 0
        && request.resource.data.get('videoCredits', 0) == 0
        && request.resource.data.get('subscriptionStatus', null) == null
        && request.resource.data.get('subscriptionId', null) == null;

      // User may update display name / photo only — all credit/tier mutations
      // go through Firebase Admin SDK (paypal-webhook, forge) on the server.
      allow update: if isOwner(uid) && onlyFields(['displayName', 'photoURL']);

      // No client-side deletes
      allow delete: if false;

      // ── users/{uid}/vault/{itemId} ────────────────────────────────────────
      match /vault/{itemId} {
        allow read,
              create,
              delete: if isOwner(uid);

        // Allow update only on the fields the client actually touches
        allow update: if isOwner(uid) && onlyFields([
          'id', 'image', 'name', 'date', 'createdAt',
          'category', 'anchors', 'strategy',
          'skinTone', 'lighting', 'camera', 'bg', 'prompt'
        ]);
      }

      // ── users/{uid}/videoVault/{itemId} ───────────────────────────────────
      match /videoVault/{itemId} {
        allow read,
              create,
              delete: if isOwner(uid);
      }

      // ── users/{uid}/generations/{genId} ──────────────────────────────────
      // Written server-side (Firebase Admin) — client can read for history UI.
      match /generations/{genId} {
        allow read:   if isOwner(uid) || isAdmin();
        allow write:  if false; // Server-side only (Admin SDK in forge.js)
      }
    }

    // ── Admin: read all users for the Studio Intelligence dashboard ───────────
    // Scoped to collection-group read; no write access.
    match /users/{uid} {
      allow read: if isAdmin();
    }

    // ── prop-covers — public read, server-write only ──────────────────────────
    match /prop-covers/{propId} {
      allow read: if true;      // gallery is publicly browsable
      allow write: if false;    // only Admin SDK (generate-prop-cover endpoint)
    }

    // ── B2B Brand Workspaces ──────────────────────────────────────────────────
    // All brand mutations go through server endpoints — client reads only.

    function isBrandMember(brandId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/brands/$(brandId)/members/$(request.auth.uid));
    }

    match /brands/{brandId} {
      allow read: if isAdmin() || isBrandMember(brandId);
      allow write: if false; // server-side only

      match /members/{uid} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /skus/{skuId} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /campaigns/{campaignId} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /vault/{assetId} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /sets/{setId} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /jobs/{jobId} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /webhookLogs/{logId} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }

      match /metrics/{date} {
        allow read: if isAdmin() || isBrandMember(brandId);
        allow write: if false;
      }
    }

    // ── Brand member collection-group read for getUserBrands() ────────────────
    match /{path=**}/members/{uid} {
      allow read: if isOwner(uid) || isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
